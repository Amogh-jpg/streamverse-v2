# ---------------------------------------------------------------------------
# StreamVerse environment variables
# Copy this file to `.env.local` and fill in the values.
# NEVER commit real secrets. Only NEXT_PUBLIC_* values are exposed to the browser.
# ---------------------------------------------------------------------------

# --- App ---
# Public base URL of the deployment (used for OAuth redirects, share links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (https://supabase.com/dashboard) ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, never exposed to client). Optional for Phase 1.
SUPABASE_SERVICE_ROLE_KEY=

# --- TMDB (https://www.themoviedb.org/settings/api) ---
# Use the API Read Access Token (v4 auth, a long JWT) OR the v3 API key.
# If both are set, the read access token is preferred.
TMDB_API_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# --- AI provider (Phase 2 — not required for Phase 1) ---
# OPENAI_API_KEY=
# GEMINI_API_KEY=
